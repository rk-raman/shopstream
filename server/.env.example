# Frontend URL
CLIENT_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5mb
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Background Jobs
REDIS_QUEUE_HOST=localhost
REDIS_QUEUE_PORT=6379