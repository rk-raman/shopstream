{
  "name": "shopstream",
  "version": "1.0.0",
  "description": "Learning node, express and mongoDB",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:docker": "docker-compose -f docker-compose.dev.yml up",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "build": "echo 'Build complete'",
    "seed": "node scripts/seedData.js",
    "db:migrate": "node scripts/migrate.js"
  },
  "author": "Jonas Schmedtmann",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.0.3",
    "redis": "^4.6.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "joi": "^17.9.1",
    "cors": "^2.8.5",
    "helmet": "^6.1.5",
    "express-rate-limit": "^6.7.0",
    "express-mongo-sanitize": "^2.2.0",
    "compression": "^1.7.4",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^1.37.0",
    "nodemailer": "^6.9.1",
    "stripe": "^12.0.0",
    "razorpay": "^2.8.6",
    "@elastic/elasticsearch": "^8.7.0",
    "kafkajs": "^2.2.4",
    "bull": "^4.10.4",
    "winston": "^3.8.2",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-facebook": "^3.0.0",
    "socket.io": "^4.6.1",
    "cron": "^2.3.0",
    "uuid": "^9.0.0",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "nodemon": "^2.0.22",
    "jest": "^29.5.0",
    "supertest": "^6.3.3"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "eslint": "^8.39.0",
    "prettier": "^2.8.8",
    "@faker-js/faker": "^7.6.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
