		{
			"name": "Cart Summary & Sync",
			"item": [
				{
					"name": "Get Cart Summary",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Cart summary contains required fields', function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response.success).to.be.true;",
									"    pm.expect(response.data.summary).to.exist;",
									"    ",
									"    const summary = response.data.summary;",
									"    pm.expect(summary.totalItems).to.be.a('number');",
									"    pm.expect(summary.totalPrice).to.be.a('number');",
									"    pm.expect(summary.totalDiscountedPrice).to.be.a('number');",
									"    pm.expect(summary.savedAmount).to.be.a('number');",
									"    pm.expect(summary.estimatedTax).to.be.a('number');",
									"    pm.expect(summary.shippingCharges).to.be.a('number');",
									"    pm.expect(summary.finalAmount).to.be.a('number');",
									"});",
									"",
									"pm.test('Tax calculation is correct', function () {",
									"    const response = pm.response.json();",
									"    const summary = response.data.summary;",
									"    const expectedTax = Math.round(summary.totalDiscountedPrice * 0.18);",
									"    pm.expect(summary.estimatedTax).to.eql(expectedTax);",
									"});",
									"",
									"pm.test('Shipping calculation is correct', function () {",
									"    const response = pm.response.json();",
									"    const summary = response.data.summary;",
									"    const expectedShipping = summary.totalDiscountedPrice > 500 ? 0 : 40;",
									"    pm.expect(summary.shippingCharges).to.eql(expectedShipping);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": "{{baseUrl}}/cart/summary"
					},
					"response": []
				},
