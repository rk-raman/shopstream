		{
			"name": "Cart Management",
			"item": [
				{
					"name": "Get Cart",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has cart data', function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response.success).to.be.true;",
									"    pm.expect(response.data.cart).to.exist;",
									"    pm.expect(response.data.cart.user).to.exist;",
									"    pm.expect(response.data.cart.items).to.be.an('array');",
									"    pm.expect(response.data.cart.totalItems).to.be.a('number');",
									"    pm.expect(response.data.cart.totalPrice).to.be.a('number');",
									"    ",
									"    // Store cart ID for future requests",
									"    pm.environment.set('cartId', response.data.cart._id);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": "{{baseUrl}}/cart"
					},
					"response": []
				},
				{
					"name": "Add Item to Cart (Without Variant)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Item added to cart', function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response.success).to.be.true;",
									"    pm.expect(response.data.cart.items.length).to.be.greaterThan(0);",
									"    pm.expect(response.data.cart.totalItems).to.be.greaterThan(0);",
									"    ",
									"    // Store item ID for future operations",
									"    const addedItem = response.data.cart.items[response.data.cart.items.length - 1];",
									"    pm.environment.set('itemId', addedItem._id);",
									"});",
									"",
									"pm.test('Message is correct', function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response.message).to.eql('Item added to cart successfully');",
									"});"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Set a sample product ID if not already set",
									"if (!pm.environment.get('productId')) {",
									"    pm.environment.set('productId', '507f1f77bcf86cd799439011');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}"
						},
						"url": "{{baseUrl}}/cart/add"
					},
					"response": []
