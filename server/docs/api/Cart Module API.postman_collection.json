					"name": "Get Abandoned Carts",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Abandoned carts retrieved', function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response.success).to.be.true;",
									"    pm.expect(response.data.abandonedCarts).to.be.an('array');",
									"    pm.expect(response.message).to.eql('Abandoned carts retrieved successfully');",
									"});",
									"",
									"pm.test('Each abandoned cart has required fields', function () {",
									"    const response = pm.response.json();",
									"    if (response.data.abandonedCarts.length > 0) {",
									"        const cart = response.data.abandonedCarts[0];",
									"        pm.expect(cart.user).to.exist;",
									"        pm.expect(cart.totalItems).to.be.greaterThan(0);",
									"        pm.expect(cart.lastModified).to.exist;",
									"    }",
									"});"
								],
