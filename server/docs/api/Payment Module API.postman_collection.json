	"item": [
		{
			"name": "Public Routes",
			"item": [
				{
					"name": "Get Supported Payment Options",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/payments/options",
						"description": "Get supported payment gateways, currencies, and payment methods"
					},
					"response": []
				},
				{
					"name": "Process Stripe Webhook",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "stripe-signature",
								"value": "t=1234567890,v1=signature_here"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"evt_1234567890\",\n  \"object\": \"event\",\n  \"api_version\": \"2020-08-27\",\n  \"created\": 1234567890,\n  \"data\": {\n    \"object\": {\n      \"id\": \"pi_1234567890\",\n      \"object\": \"payment_intent\",\n      \"amount\": 2000,\n      \"currency\": \"usd\",\n      \"status\": \"succeeded\"\n    }\n  },\n  \"livemode\": false,\n  \"pending_webhooks\": 1,\n  \"request\": {\n    \"id\": \"req_1234567890\",\n    \"idempotency_key\": null\n  },\n  \"type\": \"payment_intent.succeeded\"\n}"
						},
						"url": "{{baseUrl}}/payments/webhook/stripe",
						"description": "Webhook endpoint for Stripe payment events"
					},
					"response": []
				},
				{
					"name": "Process PayPal Webhook",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "paypal-auth-algo",
								"value": "SHA256withRSA"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"WH-1234567890\",\n  \"event_version\": \"1.0\",\n  \"create_time\": \"2023-01-01T00:00:00Z\",\n  \"resource_type\": \"payment\",\n  \"event_type\": \"PAYMENT.CAPTURE.COMPLETED\",\n  \"summary\": \"Payment completed\",\n  \"resource\": {\n    \"id\": \"PAY-1234567890\",\n    \"status\": \"COMPLETED\"\n  }\n}"
						},
						"url": "{{baseUrl}}/payments/webhook/paypal",
						"description": "Webhook endpoint for PayPal payment events"
					},
					"response": []
				}
			],
			"description": "Public endpoints that don't require authentication"
		},
