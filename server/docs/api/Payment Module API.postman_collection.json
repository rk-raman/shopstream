	"auth": {
		"type": "bearer",
		"bearer": {
			"token": "{{authToken}}"
		}
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-generate test IDs if not set",
					"if (!pm.environment.get('orderId')) {",
					"    pm.environment.set('orderId', '507f1f77bcf86cd799439011');",
					"}",
					"",
					"if (!pm.environment.get('userId')) {",
					"    pm.environment.set('userId', '507f1f77bcf86cd799439012');",
					"}",
					"",
					"// Set timestamp for unique test data",
					"pm.environment.set('timestamp', Date.now());"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Global test script for all requests",
					"pm.test('Response time is less than 5000ms', function () {",
					"    pm.expect(pm.response.responseTime).to.be.below(5000);",
					"});",
					"",
					"pm.test('Response has correct Content-Type', function () {",
					"    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
					"});",
					"",
					"// Extract paymentId from response if available",
					"if (pm.response.json() && pm.response.json().data && pm.response.json().data.payment && pm.response.json().data.payment.paymentId) {",
					"    pm.environment.set('paymentId', pm.response.json().data.payment.paymentId);",
					"    console.log('PaymentId set to: ' + pm.response.json().data.payment.paymentId);",
					"}"
				]
			}
		}
