					"        }",
					"        ",
					"        // Extract brand ID",
					"        if (responseJson.data && responseJson.data.brand && responseJson.data.brand._id) {",
					"            pm.environment.set('brand_id', responseJson.data.brand._id);",
					"        }",
					"        ",
					"        // Extract collection ID",
					"        if (responseJson.data && responseJson.data.collection && responseJson.data.collection._id) {",
					"            pm.environment.set('collection_id', responseJson.data.collection._id);",
					"        }",
					"        ",
					"        // Extract from array responses",
					"        if (responseJson.data && responseJson.data.docs && responseJson.data.docs.length > 0) {",
					"            const firstItem = responseJson.data.docs[0];",
					"            if (firstItem._id) {",
					"                const requestUrl = pm.request.url.toString();",
					"                if (requestUrl.includes('/products')) {",
					"                    pm.environment.set('product_id', firstItem._id);",
					"                } else if (requestUrl.includes('/categories')) {",
					"                    pm.environment.set('category_id', firstItem._id);",
					"                } else if (requestUrl.includes('/brands')) {",
					"                    pm.environment.set('brand_id', firstItem._id);",
					"                } else if (requestUrl.includes('/collections')) {",
					"                    pm.environment.set('collection_id', firstItem._id);",
					"                }",
					"            }",
					"        }",
					"    } catch (e) {",
					"        // Ignore JSON parsing errors",
					"        console.log('Could not parse response JSON:', e.message);",
					"    }",
					"}"
				]
			}
