					"});",
					"",
					"// Auto-extract IDs from responses for chaining requests",
					"if (pm.response.code === 200 || pm.response.code === 201) {",
					"    try {",
					"        const responseJson = pm.response.json();",
					"        ",
					"        // Extract product ID",
					"        if (responseJson.data && responseJson.data.product && responseJson.data.product._id) {",
					"            pm.environment.set('product_id', responseJson.data.product._id);",
