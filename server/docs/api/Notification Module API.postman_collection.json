							"raw": "{\n  \"name\": \"Order Confirmation Template\",\n  \"description\": \"Template for order confirmation notifications\",\n  \"type\": \"order\",\n  \"category\": \"success\",\n  \"subject\": \"Order Confirmed - {{orderNumber}}\",\n  \"title\": \"Your Order is Confirmed!\",\n  \"message\": \"Hi {{firstName}}, your order #{{orderNumber}} has been confirmed. Total amount: {{totalAmount}}. Thank you for shopping with us!\",\n  \"emailContent\": {\n    \"html\": \"<h1>Order Confirmed!</h1><p>Hi {{firstName}},</p><p>Your order #{{orderNumber}} has been confirmed.</p><p><strong>Total: {{totalAmount}}</strong></p><a href='{{orderLink}}' style='background-color: #4CAF50; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px;'>View Order</a>\",\n    \"text\": \"Order Confirmed! Hi {{firstName}}, your order #{{orderNumber}} has been confirmed. Total: {{totalAmount}}. View your order: {{orderLink}}\"\n  },\n  \"smsContent\": {\n    \"message\": \"Hi {{firstName}}, your order #{{orderNumber}} is confirmed. Total: {{totalAmount}}. Track: {{trackingLink}}\"\n  },\n  \"pushContent\": {\n    \"title\": \"Order Confirmed\",\n    \"body\": \"Order #{{orderNumber}} confirmed. Total: {{totalAmount}}\",\n    \"actionUrl\": \"/orders/{{orderId}}\",\n    \"actionText\": \"View Order\"\n  },\n  \"variables\": [\n    {\n      \"name\": \"firstName\",\n      \"type\": \"string\",\n      \"required\": true,\n      \"description\": \"Customer's first name\"\n    },\n    {\n      \"name\": \"orderNumber\",\n      \"type\": \"string\",\n      \"required\": true,\n      \"description\": \"Order number\"\n    },\n    {\n      \"name\": \"totalAmount\",\n      \"type\": \"string\",\n      \"required\": true,\n      \"description\": \"Total order amount\"\n    },\n    {\n      \"name\": \"orderLink\",\n      \"type\": \"string\",\n      \"required\": false,\n      \"description\": \"Link to view order details\"\n    }\n  ],\n  \"channels\": {\n    \"email\": {\n      \"enabled\": true,\n      \"required\": false\n    },\n    \"sms\": {\n      \"enabled\": true,\n      \"required\": false\n    },\n    \"push\": {\n      \"enabled\": true,\n      \"required\": false\n    },\n    \"inApp\": {\n      \"enabled\": true,\n      \"required\": true\n    }\n  },\n  \"priority\": \"normal\",\n  \"defaultExpiry\": 30,\n  \"autoSend\": true,\n  \"isActive\": true,\n  \"isDefault\": false,\n  \"metadata\": {\n    \"tags\": [\"order\", \"confirmation\", \"ecommerce\"],\n    \"language\": \"en\",\n    \"customData\": {\n      \"department\": \"sales\",\n      \"version\": \"1.0\"\n    }\n  }\n}"
