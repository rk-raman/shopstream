					"name": "Create Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    if (response.data && response.data.order) {",
									"        pm.environment.set('orderId', response.data.order._id);",
									"        pm.environment.set('orderNumber', response.data.order.orderNumber);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": {
								"token": "{{authToken}}"
							}
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"variantId\": \"{{variantId}}\",\n      \"quantity\": 2\n    }\n  ],\n  \"shippingAddress\": {\n    \"fullName\": \"John Doe\",\n    \"addressLine1\": \"123 Main Street\",\n    \"addressLine2\": \"Apt 4B\",\n    \"city\": \"Chennai\",\n    \"state\": \"Tamil Nadu\",\n    \"pincode\": \"600001\",\n    \"country\": \"India\",\n    \"phone\": \"+91-9876543210\"\n  },\n  \"billingAddress\": {\n    \"fullName\": \"John Doe\",\n    \"addressLine1\": \"123 Main Street\",\n    \"addressLine2\": \"Apt 4B\",\n    \"city\": \"Chennai\",\n    \"state\": \"Tamil Nadu\",\n    \"pincode\": \"600001\",\n    \"country\": \"India\",\n    \"phone\": \"+91-9876543210\"\n  },\n  \"paymentMethod\": \"cod\",\n  \"coupon\": {\n    \"code\": \"SAVE50\"\n  },\n  \"notes\": \"Please handle with care\",\n  \"specialInstructions\": \"Deliver between 9 AM - 6 PM\"\n}"
						},
						"url": "{{baseUrl}}/orders",
						"description": "Create a new order for authenticated customer"
					},
					"response": []
				},
