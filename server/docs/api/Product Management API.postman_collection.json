	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-generate test data if not present",
					"if (!pm.environment.get('productId')) {",
					"    pm.environment.set('productId', '64a1b2c3d4e5f6789012345');",
					"}",
					"if (!pm.environment.get('categoryId')) {",
					"    pm.environment.set('categoryId', '64a1b2c3d4e5f6789012346');",
					"}",
					"if (!pm.environment.get('brandId')) {",
					"    pm.environment.set('brandId', '64a1b2c3d4e5f6789012347');",
					"}",
					"if (!pm.environment.get('sellerId')) {",
					"    pm.environment.set('sellerId', '64a1b2c3d4e5f6789012348');",
					"}",
					"if (!pm.environment.get('variantId')) {",
					"    pm.environment.set('variantId', '64a1b2c3d4e5f6789012349');",
					"}",
					"if (!pm.environment.get('subcategoryId')) {",
					"    pm.environment.set('subcategoryId', '64a1b2c3d4e5f6789012366');",
					"}",
					"",
					"// Add timestamp for unique data",
					"pm.environment.set('timestamp', Date.now());",
					"",
					"// Log current request info",
					"console.log('Request:', pm.info.requestName);",
					"console.log('Method:', pm.request.method);",
					"console.log('URL:', pm.request.url);"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Common response validation tests",
					"pm.test('Response time is acceptable', function () {",
					"    pm.expect(pm.response.responseTime).to.be.below(5000);",
					"});",
					"",
					"pm.test('Status code is successful', function () {",
					"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]);",
					"});",
					"",
					"pm.test('Response has proper content type', function () {",
					"    if (pm.response.code !== 204) {",
					"        pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
					"    }",
					"});",
					"",
					"// Validate successful responses",
					"if (pm.response.code === 200 || pm.response.code === 201) {",
					"    pm.test('Response has success property', function () {",
					"        const jsonData = pm.response.json();",
					"        pm.expect(jsonData).to.have.property('success');",
					"        pm.expect(jsonData.success).to.be.true;",
					"    });",
					"",
					"    pm.test('Response has message property', function () {",
					"        const jsonData = pm.response.json();",
					"        pm.expect(jsonData).to.have.property('message');",
					"        pm.expect(jsonData.message).to.be.a('string');",
					"        pm.expect(jsonData.message.length).to.be.above(0);",
					"    });",
					"",
					"    // Extract and store important IDs from responses",
					"    const jsonData = pm.response.json();",
					"",
					"    // Store product ID from create operations",
					"    if (pm.request.method === 'POST' && pm.request.url.path.includes('products') && !pm.request.url.path.includes('bulk')) {",
					"        if (jsonData.data && jsonData.data.product && jsonData.data.product._id) {",
					"            pm.environment.set('lastCreatedProductId', jsonData.data.product._id);",
					"            console.log('✅ Created Product ID:', jsonData.data.product._id);",
					"        }",
					"    }",
					"",
					"    // Store variant ID from variant creation",
					"    if (pm.request.method === 'POST' && pm.request.url.path.includes('variants')) {",
					"        if (jsonData.data && jsonData.data.product && jsonData.data.product.variants) {",
					"            const variants = jsonData.data.product.variants;",
					"            if (variants.length > 0) {",
					"                const lastVariant = variants[variants.length - 1];",
					"                pm.environment.set('lastCreatedVariantId', lastVariant._id);",
					"                console.log('✅ Created Variant ID:', lastVariant._id);",
					"            }",
					"        }",
					"    }",
					"",
					"    // Validate pagination for list endpoints",
					"    if (jsonData.data && jsonData.data.docs) {",
					"        pm.test('Pagination data is present', function () {",
					"            pm.expect(jsonData.data).to.have.property('totalDocs');",
					"            pm.expect(jsonData.data).to.have.property('limit');",
					"            pm.expect(jsonData.data).to.have.property('page');",
					"            pm.expect(jsonData.data).to.have.property('totalPages');",
					"        });",
					"    }",
					"",
					"    // Validate product structure for product endpoints",
					"    if (jsonData.data && jsonData.data.product) {",
					"        pm.test('Product has required fields', function () {",
					"            const product = jsonData.data.product;",
					"            pm.expect(product).to.have.property('_id');",
					"            pm.expect(product).to.have.property('name');",
					"            pm.expect(product).to.have.property('slug');",
					"            pm.expect(product).to.have.property('basePrice');",
					"            pm.expect(product).to.have.property('status');",
					"        });",
					"    }",
					"}",
					"",
					"// Handle error responses",
					"if (pm.response.code >= 400) {",
					"    pm.test('Error response has proper structure', function () {",
					"        if (pm.response.headers.get('Content-Type') && pm.response.headers.get('Content-Type').includes('application/json')) {",
					"            const jsonData = pm.response.json();",
					"            pm.expect(jsonData).to.have.property('success');",
					"            pm.expect(jsonData.success).to.be.false;",
					"            pm.expect(jsonData).to.have.property('message');",
					"        }",
					"    });",
					"",
					"    console.log('❌ Request failed:', pm.response.code, pm.response.status);",
					"    if (pm.response.json && pm.response.json().message) {",
					"        console.log('Error message:', pm.response.json().message);",
					"    }",
					"}",
					"",
					"// Log successful operations",
					"if (pm.response.code < 400) {",
					"    console.log('✅ Request successful:', pm.info.requestName);",
					"}"
				]
			}
		}
	],
