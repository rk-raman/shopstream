							"raw": "{\n  \"name\": \"Premium Gaming Laptop RTX 4080\",\n  \"slug\": \"premium-gaming-laptop-rtx-4080\",\n  \"description\": \"High-end gaming laptop with latest RTX 4080 GPU, Intel i9 processor, and 32GB RAM. Perfect for gaming, content creation, and professional work. Features a stunning 15.6-inch 4K OLED display with 120Hz refresh rate for smooth gaming experience.\",\n  \"shortDescription\": \"Premium gaming laptop with RTX 4080 GPU, Intel i9 processor, and 32GB RAM for ultimate performance.\",\n  \"category\": \"{{categoryId}}\",\n  \"subcategory\": \"{{subcategoryId}}\",\n  \"brand\": \"{{brandId}}\",\n  \"tags\": [\"gaming\", \"laptop\", \"rtx\", \"i9\", \"premium\", \"4k\", \"oled\"],\n  \"basePrice\": 2499.99,\n  \"discountPrice\": 2299.99,\n  \"discountPercentage\": 8,\n  \"images\": [\n    {\n      \"url\": \"https://example.com/laptop-main.jpg\",\n      \"isMain\": true,\n      \"public_id\": \"laptop_main_001\",\n      \"alt\": \"Gaming laptop front view\"\n    },\n    {\n      \"url\": \"https://example.com/laptop-side.jpg\",\n      \"isMain\": false,\n      \"public_id\": \"laptop_side_001\",\n      \"alt\": \"Gaming laptop side view\"\n    },\n    {\n      \"url\": \"https://example.com/laptop-keyboard.jpg\",\n      \"isMain\": false,\n      \"public_id\": \"laptop_keyboard_001\",\n      \"alt\": \"Gaming laptop keyboard RGB lighting\"\n    }\n  ],\n  \"videos\": [\n    {\n      \"url\": \"https://example.com/laptop-demo.mp4\",\n      \"public_id\": \"laptop_demo_001\",\n      \"thumbnail\": \"https://example.com/laptop-demo-thumb.jpg\",\n      \"duration\": 120\n    }\n  ],\n  \"stock\": 25,\n  \"sku\": \"GAMING-LAPTOP-RTX4080-001\",\n  \"specifications\": [\n    {\n      \"name\": \"Processor\",\n      \"value\": \"Intel Core i9-12900H (14 cores, up to 5.0 GHz)\",\n      \"category\": \"technical\"\n    },\n    {\n      \"name\": \"Graphics Card\",\n      \"value\": \"NVIDIA RTX 4080 8GB GDDR6X\",\n      \"category\": \"technical\"\n    },\n    {\n      \"name\": \"RAM\",\n      \"value\": \"32GB DDR5-4800MHz (2x16GB)\",\n      \"category\": \"technical\"\n    },\n    {\n      \"name\": \"Storage\",\n      \"value\": \"1TB NVMe SSD PCIe 4.0\",\n      \"category\": \"technical\"\n    },\n    {\n      \"name\": \"Display\",\n      \"value\": \"15.6\\\" 4K OLED (3840x2160) 120Hz\",\n      \"category\": \"physical\"\n    },\n    {\n      \"name\": \"Weight\",\n      \"value\": \"2.3 kg\",\n      \"category\": \"physical\"\n    },\n    {\n      \"name\": \"Battery\",\n      \"value\": \"90Wh Li-ion, up to 8 hours\",\n      \"category\": \"performance\"\n    },\n    {\n      \"name\": \"Ports\",\n      \"value\": \"3x USB 3.2, 1x USB-C, HDMI 2.1, Ethernet\",\n      \"category\": \"compatibility\"\n    }\n  ],\n  \"weight\": 2300,\n  \"dimensions\": {\n    \"length\": 35.5,\n    \"width\": 25.4,\n    \"height\": 2.3,\n    \"unit\": \"cm\"\n  },\n  \"shippingClass\": \"standard\",\n  \"lowStockThreshold\": 5,\n  \"isDigital\": false,\n  \"metaTitle\": \"Premium Gaming Laptop RTX 4080 - High Performance Gaming\",\n  \"metaDescription\": \"Experience ultimate gaming performance with our premium laptop featuring RTX 4080 GPU and Intel i9 processor. 4K OLED display, 32GB RAM. Fast shipping available.\",\n  \"metaKeywords\": [\"gaming laptop\", \"rtx 4080\", \"intel i9\", \"premium laptop\", \"4k oled\"]\n}"
